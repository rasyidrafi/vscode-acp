{
  "name": "oacp",
  "displayName": "OACP",
  "description": "Open ACP client VS Code extension — connect to GitHub Copilot, Claude Code, Gemini CLI, Qwen Code, Codex CLI, OpenCode, OpenClaw, Hermes Agent, and any ACP-compatible AI coding agent",
  "version": "0.4.1",
  "publisher": "rasyidrafi",
  "author": "rasyidrafi",
  "license": "MIT",
  "icon": "resources/icon.png",
  "bugs": {
    "url": "https://github.com/rasyidrafi/vscode-oacp/issues"
  },
  "homepage": "https://github.com/rasyidrafi/vscode-oacp/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/rasyidrafi/vscode-oacp.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "acp",
    "agent",
    "ai",
    "coding agent",
    "copilot"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "oacp",
          "title": "OACP",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "oacp": [
        {
          "id": "acp-sessions",
          "name": "Agents",
          "type": "tree"
        },
        {
          "id": "acp-chat",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "acp-sessions",
        "contents": "No agents configured.\n[Add Agent](command:acp.addAgent)\nConfigure agents in settings or browse the [Agent Registry](command:acp.browseRegistry)."
      },
      {
        "view": "acp-chat",
        "contents": "Start chatting with an AI coding agent.\n[Connect to Agent](command:acp.connectAgent)\nSelect an agent from the list above to begin."
      }
    ],
    "commands": [
      {
        "command": "acp.connectAgent",
        "title": "OACP: Connect to Agent",
        "icon": "$(plug)"
      },
      {
        "command": "acp.newConversation",
        "title": "OACP: New Conversation",
        "icon": "$(add)"
      },
      {
        "command": "acp.sendPrompt",
        "title": "OACP: Send Prompt"
      },
      {
        "command": "acp.cancelTurn",
        "title": "OACP: Cancel Current Turn",
        "icon": "$(debug-stop)"
      },
      {
        "command": "acp.disconnectAgent",
        "title": "OACP: Disconnect Agent",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "acp.openChat",
        "title": "OACP: Open Chat Panel"
      },
      {
        "command": "acp.addAgent",
        "title": "OACP: Add Agent Configuration",
        "icon": "$(add)"
      },
      {
        "command": "acp.removeAgent",
        "title": "OACP: Remove Agent"
      },
      {
        "command": "acp.showLog",
        "title": "OACP: Show Log"
      },
      {
        "command": "acp.showTraffic",
        "title": "OACP: Show Protocol Traffic"
      },
      {
        "command": "acp.browseRegistry",
        "title": "OACP: Browse Agent Registry"
      },
      {
        "command": "acp.setMode",
        "title": "OACP: Set Agent Mode"
      },
      {
        "command": "acp.setModel",
        "title": "OACP: Set Agent Model"
      },
      {
        "command": "acp.attachFile",
        "title": "OACP: Attach File to Prompt",
        "icon": "$(attach)"
      },
      {
        "command": "acp.refreshAgents",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "acp.openSettings",
        "title": "OACP Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "acp.restartAgent",
        "title": "OACP: Restart Agent",
        "icon": "$(debug-restart)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "acp.addAgent",
          "when": "view == acp-sessions",
          "group": "navigation@1"
        },
        {
          "command": "acp.refreshAgents",
          "when": "view == acp-sessions",
          "group": "navigation@2"
        },
        {
          "command": "acp.browseRegistry",
          "when": "view == acp-sessions",
          "group": "navigation@3"
        },
        {
          "command": "acp.openSettings",
          "when": "view == acp-sessions",
          "group": "z_acp@1"
        },
        {
          "command": "acp.newConversation",
          "when": "view == acp-chat",
          "group": "navigation@1"
        },
        {
          "command": "acp.attachFile",
          "when": "view == acp-chat",
          "group": "navigation@2"
        },
        {
          "command": "acp.cancelTurn",
          "when": "view == acp-chat && acp.turnInProgress",
          "group": "navigation@3"
        },
        {
          "command": "acp.disconnectAgent",
          "when": "view == acp-chat",
          "group": "navigation@4"
        },
        {
          "command": "acp.openSettings",
          "when": "view == acp-chat",
          "group": "z_acp@1"
        },
        {
          "command": "acp.restartAgent",
          "when": "view == acp-chat",
          "group": "z_acp@2"
        },
        {
          "command": "acp.showLog",
          "when": "view == acp-chat",
          "group": "z_acp@3"
        },
        {
          "command": "acp.showTraffic",
          "when": "view == acp-chat",
          "group": "z_acp@4"
        }
      ],
      "view/item/context": [
        {
          "command": "acp.connectAgent",
          "when": "view == acp-sessions && viewItem == agent-disconnected",
          "group": "inline"
        },
        {
          "command": "acp.disconnectAgent",
          "when": "view == acp-sessions && viewItem == agent-connected",
          "group": "inline"
        },
        {
          "command": "acp.removeAgent",
          "when": "view == acp-sessions && viewItem =~ /^agent/"
        },
        {
          "command": "acp.restartAgent",
          "when": "view == acp-sessions && viewItem == agent-connected"
        }
      ]
    },
    "keybindings": [
      {
        "command": "acp.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "acp.cancelTurn",
        "key": "escape",
        "when": "acp.turnInProgress"
      }
    ],
    "configuration": {
      "title": "OACP",
      "properties": {
        "acp.agents": {
          "type": "object",
          "description": "Agent configurations. Each key is the agent name. Optional binaryPath takes priority, then binaryName is resolved from PATH, then command plus args is used as fallback.",
          "default": {
            "GitHub Copilot": {
              "binaryName": "copilot",
              "binaryArgs": [
                "--acp"
              ],
              "binaryPath": "",
              "command": "npx",
              "args": [
                "@github/copilot-language-server@latest",
                "--acp"
              ],
              "env": {}
            },
            "Claude Code": {
              "command": "npx",
              "args": [
                "@zed-industries/claude-code-acp@latest"
              ],
              "env": {}
            },
            "Gemini CLI": {
              "binaryName": "gemini",
              "binaryArgs": [
                "--acp"
              ],
              "binaryPath": "",
              "command": "npx",
              "args": [
                "@google/gemini-cli@latest",
                "--acp"
              ],
              "env": {}
            },
            "Qwen Code": {
              "command": "npx",
              "args": [
                "@qwen-code/qwen-code@latest",
                "--acp",
                "--experimental-skills"
              ],
              "env": {}
            },
            "Auggie CLI": {
              "command": "npx",
              "args": [
                "@augmentcode/auggie@latest",
                "--acp"
              ],
              "env": {
                "AUGMENT_DISABLE_AUTO_UPDATE": "1"
              }
            },
            "Qoder CLI": {
              "command": "npx",
              "args": [
                "@qoder-ai/qodercli@latest",
                "--acp"
              ],
              "env": {}
            },
            "Codex CLI": {
              "command": "npx",
              "args": [
                "@zed-industries/codex-acp@latest"
              ],
              "env": {}
            },
            "OpenCode": {
              "command": "npx",
              "args": [
                "opencode-ai@latest",
                "acp"
              ],
              "env": {}
            },
            "OpenClaw": {
              "command": "npx",
              "args": [
                "openclaw",
                "acp"
              ],
              "env": {}
            },
            "Kiro CLI": {
              "command": "kiro-cli",
              "args": [
                "acp"
              ],
              "env": {}
            },
            "Hermes Agent": {
              "command": "hermes",
              "args": [
                "acp"
              ],
              "env": {}
            }
          }
        },
        "acp.autoApprovePermissions": {
          "type": "string",
          "enum": [
            "ask",
            "allowAll"
          ],
          "default": "ask",
          "description": "Automatically approve agent permission requests. 'ask' always prompts, 'allowAll' approves everything."
        },
        "acp.defaultWorkingDirectory": {
          "type": "string",
          "default": "",
          "description": "Default working directory for agent sessions. Leave empty to use the current workspace folder."
        },
        "acp.autoOpenWrittenFilesInEditor": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open files in the editor after an ACP file write completes."
        },
        "acp.logTraffic": {
          "type": "boolean",
          "default": true,
          "description": "Log all ACP protocol traffic to the output channel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run compile:extension && npm run compile:webview",
    "compile:extension": "webpack",
    "compile:webview": "vite build --mode development",
    "watch": "npm run watch:extension",
    "watch:extension": "webpack --watch",
    "watch:webview": "vite --host 127.0.0.1",
    "package": "npm run package:extension && npm run package:webview",
    "package:extension": "webpack --mode production --devtool hidden-source-map",
    "package:webview": "vite build",
    "typecheck": "tsc -p . --noEmit && tsc -p webview/tsconfig.json",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "lint": "eslint src --max-warnings 0",
    "test:unit": "vitest run --root . --exclude '**/node_modules/**' --exclude '**/dist/**' --exclude '**/out/**' webview src/core src/handlers src/utils src/shared src/config src/ui",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "test": "vscode-test"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@vscode/extension-telemetry": "^1.5.0",
    "lucide-react": "^1.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.0"
  }
}

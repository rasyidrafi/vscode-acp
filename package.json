{
  "name": "oacp",
  "displayName": "OACP",
  "description": "Open ACP client VS Code extension — connect to GitHub Copilot, Claude Code, Gemini CLI, Qwen Code, Codex CLI, OpenCode, OpenClaw, Hermes Agent, and any ACP-compatible AI coding agent",
  "version": "0.5.14",
  "publisher": "rasyidrafi",
  "author": "rasyidrafi",
  "license": "MIT",
  "icon": "resources/icon.png",
  "bugs": {
    "url": "https://github.com/rasyidrafi/vscode-oacp/issues"
  },
  "homepage": "https://github.com/rasyidrafi/vscode-oacp/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/rasyidrafi/vscode-oacp.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "acp",
    "agent",
    "ai",
    "coding agent",
    "copilot"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "oacp",
          "title": "OACP",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "oacp": [
        {
          "id": "acp-sessions",
          "name": "Agents",
          "type": "tree"
        },
        {
          "id": "acp-chat",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "acp-sessions",
        "contents": "No agents added. [Add Agent](command:acp.addAgent) from the ACP registry."
      },
      {
        "view": "acp-chat",
        "contents": "Start chatting with an AI coding agent.\n[Create Agent Instance](command:acp.connectAgent)\nSelect a connected session from the Agents list to begin."
      }
    ],
    "commands": [
      {
        "command": "acp.connectAgent",
        "title": "OACP: Create Agent Instance",
        "icon": "$(plug)"
      },
      {
        "command": "acp.openSession",
        "title": "OACP: Open Session",
        "icon": "$(go-to-file)"
      },
      {
        "command": "acp.newConversation",
        "title": "OACP: New Conversation",
        "icon": "$(add)"
      },
      {
        "command": "acp.sendPrompt",
        "title": "OACP: Send Prompt"
      },
      {
        "command": "acp.cancelTurn",
        "title": "OACP: Cancel Current Turn",
        "icon": "$(debug-stop)"
      },
      {
        "command": "acp.disconnectAgent",
        "title": "OACP: Disconnect Agent",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "acp.disconnectSession",
        "title": "OACP: Disconnect Session",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "acp.disconnectActiveSession",
        "title": "OACP: Disconnect Active Session",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "acp.openChat",
        "title": "OACP: Open Chat Panel"
      },
      {
        "command": "acp.addAgent",
        "title": "OACP: Add Agent",
        "icon": "$(add)"
      },
      {
        "command": "acp.editAgent",
        "title": "OACP: Edit Agent Configuration",
        "icon": "$(gear)"
      },
      {
        "command": "acp.removeAgent",
        "title": "OACP: Remove Agent",
        "icon": "$(trash)"
      },
      {
        "command": "acp.showLog",
        "title": "OACP: Show Log"
      },
      {
        "command": "acp.showTraffic",
        "title": "OACP: Show Protocol Traffic"
      },
      {
        "command": "acp.setMode",
        "title": "OACP: Set Agent Mode"
      },
      {
        "command": "acp.setModel",
        "title": "OACP: Set Agent Model"
      },
      {
        "command": "acp.attachFile",
        "title": "OACP: Attach File to Prompt",
        "icon": "$(attach)"
      },
      {
        "command": "acp.openSettings",
        "title": "OACP: Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "acp.restartAgent",
        "title": "OACP: Restart Agent",
        "icon": "$(debug-restart)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "acp.addAgent",
          "when": "view == acp-sessions",
          "group": "navigation@1"
        },
        {
          "command": "acp.openSettings",
          "when": "view == acp-sessions",
          "group": "z_acp@1"
        },
        {
          "command": "acp.newConversation",
          "when": "view == acp-chat",
          "group": "navigation@1"
        },
        {
          "command": "acp.disconnectActiveSession",
          "when": "view == acp-chat && acp.hasActiveSession",
          "group": "navigation@2"
        },
        {
          "command": "acp.cancelTurn",
          "when": "view == acp-chat && acp.turnInProgress",
          "group": "navigation@3"
        },
        {
          "command": "acp.openSettings",
          "when": "view == acp-chat",
          "group": "z_acp@1"
        },
        {
          "command": "acp.showLog",
          "when": "view == acp-chat",
          "group": "z_acp@3"
        },
        {
          "command": "acp.showTraffic",
          "when": "view == acp-chat",
          "group": "z_acp@4"
        }
      ],
      "view/item/context": [
        {
          "command": "acp.connectAgent",
          "when": "view == acp-sessions && viewItem =~ /^agent/",
          "group": "inline"
        },
        {
          "command": "acp.openSession",
          "when": "view == acp-sessions && viewItem =~ /^session/",
          "group": "inline"
        },
        {
          "command": "acp.disconnectSession",
          "when": "view == acp-sessions && viewItem =~ /^session/",
          "group": "inline@2"
        },
        {
          "command": "acp.editAgent",
          "when": "view == acp-sessions && viewItem =~ /configurable/",
          "group": "inline@3"
        },
        {
          "command": "acp.removeAgent",
          "when": "view == acp-sessions && viewItem =~ /^agent/",
          "group": "inline@4"
        }
      ]
    },
    "keybindings": [
      {
        "command": "acp.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "acp.cancelTurn",
        "key": "escape",
        "when": "acp.turnInProgress"
      }
    ],
    "configuration": {
      "title": "OACP",
      "properties": {
        "oacp.agents": {
          "type": "object",
          "description": "Added ACP agents keyed by registry id. Add agents from the ACP registry; Gemini and GitHub Copilot entries may optionally override binaryPath while keeping registry fallback launch settings.",
          "default": {}
        },
        "oacp.autoApprovePermissions": {
          "type": "string",
          "enum": [
            "ask",
            "allowAll"
          ],
          "default": "ask",
          "description": "Automatically approve agent permission requests. 'ask' always prompts, 'allowAll' approves everything."
        },
        "oacp.defaultWorkingDirectory": {
          "type": "string",
          "default": "",
          "description": "Default working directory for agent sessions. Leave empty to use the current workspace folder."
        },
        "oacp.autoOpenWrittenFilesInEditor": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open files in the editor after an ACP file write completes."
        },
        "oacp.logTraffic": {
          "type": "boolean",
          "default": true,
          "description": "Log all ACP protocol traffic to the output channel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run compile:extension && npm run compile:webview",
    "compile:extension": "webpack",
    "compile:webview": "vite build --mode development",
    "watch": "npm run watch:extension",
    "watch:extension": "webpack --watch",
    "watch:webview": "vite --host 127.0.0.1",
    "package": "npm run package:extension && npm run package:webview",
    "package:extension": "webpack --mode production --devtool hidden-source-map",
    "package:webview": "vite build",
    "typecheck": "tsc -p . --noEmit && tsc -p webview/tsconfig.json",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "lint": "eslint src --max-warnings 0",
    "test:unit": "vitest run --root . --exclude '**/node_modules/**' --exclude '**/dist/**' --exclude '**/out/**' webview src/core src/handlers src/utils src/shared src/config src/ui",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "test": "vscode-test"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@vscode/extension-telemetry": "^1.5.0",
    "lucide-react": "^1.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.0"
  }
}
